NODE_ENV=development
PORT=3100
CLAUDE_COMMAND=claude
DATA_DIR=./data
CACHE_DIR=./data/cache
LOG_DIR=./data/logs
DB_PATH=./data/sqlite/sessions.json
WORKSPACE_ROOT=./workspace
MAX_IMAGE_SIZE_MB=10
MAX_FILE_SIZE_MB=30
REQUEST_TIMEOUT_MS=180000
MAX_REPLY_CHARS=1800
WECHAT_ADAPTER_MODE=local-dev
DEV_INBOX_DIR=./data/dev-inbox
DEV_OUTBOX_DIR=./data/dev-outbox
DEV_PROCESSED_DIR=./data/dev-processed
POLL_INTERVAL_MS=2000
WECHAT_SESSION_FILE=./data/wechat/session.json
WECHAT_RECEIPT_MESSAGE=已收到，正在处理...
WECHAT_MIN_RECEIPT_VISIBLE_MS=1500
